term = xterm-256color
working-directory = /Users/tywr
background-opacity = 0.95
background-blur = true
background-opacity-cells = true

# The syntax is "key = value". The whitespace around the
# equals doesn't matter.
theme = /Users/tywr/.config/colorthemes/ghostty/gravity

# Comments start with a `#` and are only valid on their own line.
# Blank lines are ignored!

keybind = ctrl+z=close_surface
keybind = ctrl+d=new_split:right

font-family = "JetBrains Mono"
font-size = 18
font-feature = cv01, cv06, cv11, cv18, cv12, cv14, cv07
adjust-cell-width = -4%
adjust-cell-height = -8%

adjust-cursor-thickness = 4
cursor-style-blink = true

# window-decoration = auto
macos-titlebar-style = hidden

window-padding-x = 10
window-padding-y = 10
window-padding-balance = true

palette-generate = true

mouse-hide-while-typing = true

window-vsync = true

copy-on-select = true
confirm-close-surface = false

shell-integration = zsh
macos-icon = custom-style
macos-icon-ghost-color = #88c0d0

scrollback-limit = 10000
